{
  "designs_dir": "./data",
  "fem_data_output": "./data",
  "voxel_resolution": 64,
  "use_sdf": false,
  "latent_dim": 32,
  "batch_size": 16,
  "epochs": 500,
  "learning_rate": 0.0003,
  "beta_vae": 0.05,
  "pos_weight": 30.0,
  "device": "cuda",
  "n_optimization_iterations": 1000,
  "output_dir": "./results",
  "freecad_path": null,
  "seed": 42,
  "n_init_points": 5,
  "checkpoint_dir": "./checkpoints",
  "log_dir": "./logs",
  "optimization": {
    "acquisition_function": "UCB",
    "beta": 0.1,
    "use_botorch": true,
    "num_restarts": 3,
    "raw_samples": 64,
    "max_iterations": 100,
    "parallel_evaluations": 8
  },
  "performance_weights": {
    "stress": 1.0,
    "compliance": 0.1,
    "mass": 0.05
  },
  "performance_targets": {
    "max_stress_mpa": 40.0,
    "yield_safety_factor": 1.5,
    "max_displacement_mm": 2.0
  },
  "manufacturing_constraints": {
    "min_feature_size_mm": 5.0,
    "max_overhang_angle_deg": 45.0,
    "min_volume_fraction": 0.15
  }
}
