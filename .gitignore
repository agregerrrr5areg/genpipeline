# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/

# ── Virtual environment ───────────────────────────────────────────────────────
venv/
.venv/

# ── Model checkpoints — large binaries, reproducible by retraining ────────────
checkpoints/

