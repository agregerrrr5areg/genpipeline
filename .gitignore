/tmp/bo_variants/
/tmp/bo_validate/

# ── Optimization results — large/binary, keep the JSON summaries only ─────────
optimization_results/*
!optimization_results/synthetic_run.json
!optimization_results/real_run.json

# ── Training logs ─────────────────────────────────────────────────────────────
logs/

# ── Simulation config (local machine-specific, may contain paths) ─────────────
sim_config.json

# ── Temp/scratch files ────────────────────────────────────────────────────────
temp_*.py

# ── Aider ─────────────────────────────────────────────────────────────────────
.aider*

# ── pytest cache ─────────────────────────────────────────────────────────────
.pytest_cache/

